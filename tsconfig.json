{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    // 1. Uklonjen baseUrl (izvor greške)
    
    "paths": {
      // 2. Putanje ostaju iste, one sada rade relativno u odnosu na ovaj fajl
      "@/*": ["./*"]
    },
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "module": "esnext",
    
    // 3. Promenjeno sa "node" na "bundler" (ovo rešava potrebu za baseUrl)
    "moduleResolution": "bundler", 
    
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    // 4. Slobodno podigni target na ES2022 za bolju optimizaciju (opciono)
    "target": "ES2022" 
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/dev/types/**/*.ts",
    "additional-modules.d.ts" // Dodaj ako si pravio fajl za CSS deklaracije
  ],
  "exclude": ["node_modules"]
}